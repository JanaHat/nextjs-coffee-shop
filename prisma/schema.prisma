generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PaymentStatus {
  PAID
  FAILED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  accounts Account[]
  sessions Session[]
  orders   Order[]
  favourites Favourite[]
  recommendationSnapshots RecommendationSnapshot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecommendationSnapshot {
  id               String   @id @default(cuid())
  userId           String
  clientSnapshotId String
  createdAt        DateTime
  items            Json
  savedAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clientSnapshotId])
  @@index([userId])
  @@index([createdAt])
}

model Favourite {
  id        String   @id @default(cuid())
  userId    String
  productId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Order {
  id           String        @id @default(cuid())
  userId       String
  status       PaymentStatus
  currency     String        @default("EUR")
  totalCents   Int
  placedAt     DateTime      @default(now())
  failureCode  String?
  failureLabel String?

  fullName     String
  email        String
  addressLine1 String
  city         String
  postalCode   String
  country      String

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id             String @id @default(cuid())
  orderId        String
  productId      String
  productName    String
  productBrand   String
  quantity       Int
  unitPriceCents Int
  imageUrl       String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
}